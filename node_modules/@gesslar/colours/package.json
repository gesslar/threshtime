{
  "name": "@gesslar/colours",
  "description": "256 colours for your terminal expressions. You're welcome.",
  "author": {
    "name": "gesslar",
    "email": "bmw@gesslar.dev",
    "url": "https://gesslar.dev"
  },
  "version": "1.0.0",
  "license": "0BSD",
  "homepage": "https://github.com/gesslar/colours#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gesslar/colours.git"
  },
  "keywords": [
    "colours",
    "256",
    "curious",
    "george",
    "ansi",
    "ascii",
    "trifle",
    "monkeynado"
  ],
  "type": "module",
  "main": "src/Colours.js",
  "bin": "src/cli.js",
  "exports": {
    ".": {
      "types": "./types/Colours.d.ts",
      "default": "./src/Colours.js"
    }
  },
  "files": [
    "src/",
    "types/",
    "LICENSE.txt"
  ],
  "engines": {
    "node": ">=24.11.0"
  },
  "scripts": {
    "lint": "eslint src/",
    "test": "node --test test/**/*.test.js",
    "test:coverage": "node --experimental-config-file=node.config.json --experimental-test-coverage --test-timeout=3000 --test test/**/*.test.js",
    "test:visual": "node test/test.js",
    "test-colours": "node src/cli.js",
    "clean": "rm -rfv ./dist",
    "build": "mkdir -pv ./dist && npm pack --pack-destination ./dist/",
    "update": "npx npm-check-updates -u && npm install",
    "submit": "npm publish --access public --//registry.npmjs.org/:_authToken=\"${NPM_ACCESS_TOKEN}\"",
    "pr": "gt submit -p --ai",
    "patch": "npm version patch",
    "minor": "npm version minor",
    "major": "npm version major",
    "types": "node -e \"require('fs').rmSync('types',{recursive:true,force:true});\" && tsc -p tsconfig.types.json"
  },
  "devDependencies": {
    "@gesslar/uglier": "^2.4.0",
    "eslint": "^10.2.0",
    "typescript": "^6.0.2"
  }
}
